// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required, immutable)
//   - username: string (required, 3-20 chars)
//   - email: string (required)
//   - character: map (optional)
//   - selectedStream: string (optional)
//   - onboarded: bool (optional)
//   - theme: string (optional)
//   - language: string (optional)
//   - streak: map (optional)
//
// Collection: usernames
// Document ID: {username}
// Fields:
//   - uid: string (required, owner)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Domain Validators
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.email is string && data.email.size() < 100 &&
             (!('character' in data) || data.character is map) &&
             (!('streak' in data) || data.streak is map);
    }

    function isValidQuest(data) {
      return data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.subject is string &&
             data.completed is bool;
    }

    function isValidPlannerBlock(data) {
      return data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.startTime is string &&
             data.endTime is string;
    }

    function isValidPublicProfile(data) {
      return data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             (!('level' in data) || data.level is number);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId}/quests/{questId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidQuest(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/planner/{blockId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidPlannerBlock(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/friends/{friendId} {
      allow read, write: if isOwner(userId);
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidPublicProfile(request.resource.data);
    }

    match /guilds/{guildId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.leaderId == request.auth.uid;
      allow update: if isAuthenticated(); // Simplified for now
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      username.size() >= 3 && username.size() <= 20;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
